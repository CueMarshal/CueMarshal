{"$schema":"http://json-schema.org/draft-07/schema#","title":"Improvement Findings Schema","description":"Schema for scanner output from the deterministic improvement discovery pipeline","type":"object","properties":{"version":{"type":"string","description":"Schema version","const":"1.0.0"},"scan_timestamp":{"type":"string","format":"date-time","description":"ISO 8601 timestamp when scan was performed"},"repository":{"type":"object","properties":{"url":{"type":"string","description":"Repository URL"},"commit_sha":{"type":"string","description":"Git commit SHA of the scanned codebase"},"branch":{"type":"string","description":"Git branch name"}},"required":["commit_sha","branch"]},"scanners":{"type":"object","properties":{"todo_markers":{"type":"object","properties":{"enabled":{"type":"boolean"},"findings_count":{"type":"integer"}}},"dependency_updates":{"type":"object","properties":{"enabled":{"type":"boolean"},"findings_count":{"type":"integer"}}},"test_coverage":{"type":"object","properties":{"enabled":{"type":"boolean"},"findings_count":{"type":"integer"}}},"stale_documentation":{"type":"object","properties":{"enabled":{"type":"boolean"},"findings_count":{"type":"integer"}}},"sonarqube":{"type":"object","properties":{"enabled":{"type":"boolean"},"findings_count":{"type":"integer"}}}}},"findings":{"type":"array","description":"Array of all findings from all scanners","items":{"type":"object","properties":{"id":{"type":"string","description":"Unique identifier for this finding (hash of location + type)"},"source":{"type":"string","enum":["todo_markers","dependency_updates","test_coverage","stale_documentation","sonarqube"],"description":"Which scanner produced this finding"},"category":{"type":"string","enum":["code_quality","testing","documentation","dependencies","technical_debt"],"description":"High-level category of the improvement"},"severity":{"type":"string","enum":["critical","high","medium","low","info"],"description":"Severity level of the finding"},"prior