# ═══════════════════════════════════════════════════════════════════════
# CueMarshal Platform Configuration
# ═══════════════════════════════════════════════════════════════════════
# This file documents ALL environment variables for the platform.
# 
# Quick Start:
#   1. Run: ./install.sh (interactive wizard)
#   OR
#   2. Copy this file: cp .env.example .env
#   3. Replace all CHANGE_ME values with secure secrets
#   4. Set at least one LLM provider API key
#   5. Run: docker compose up -d
#
# CRITICAL: Never commit the .env file - it contains secrets!
# ═══════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════
# Workspace Identity
# ═══════════════════════════════════════════
# Used for organization and repository naming in Gitea
CONDUCTOR_ORG=cuemarshal
CONDUCTOR_REPO=cuemarshal

# ═══════════════════════════════════════════
# Template repository (GitHub)
# ═══════════════════════════════════════════
# Base URL for fetching workflow and scanner templates when initializing new
# project repos. Points to the raw GitHub content of the CueMarshal source repo.
# Override to pin a specific branch or tag (e.g. .../refs/tags/v1.2.0).
TEMPLATE_REPO_URL=https://raw.githubusercontent.com/CueMarshal/CueMarshal/main

# ═══════════════════════════════════════════
# Database (PostgreSQL)
# ═══════════════════════════════════════════
# REQUIRED: Change POSTGRES_PASSWORD before deployment
POSTGRES_USER=cuemarshal
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=cuemarshal
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ═══════════════════════════════════════════
# Cache & Queue (Redis)
# ═══════════════════════════════════════════
# REQUIRED: Change REDIS_PASSWORD before deployment
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ═══════════════════════════════════════════
# Gitea (Git Server)
# ═══════════════════════════════════════════
# REQUIRED: Change GITEA_ADMIN_PASSWORD before deployment
GITEA_URL=http://gitea:3000
GITEA_ADMIN_USER=cuemarshal-admin
GITEA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
GITEA_ADMIN_EMAIL=admin@cuemarshal.local
# Browser-facing Gitea URL settings (may differ from internal GITEA_URL)
GITEA_ROOT_URL=http://localhost:3300/
GITEA_DOMAIN=localhost
GITEA_SSH_DOMAIN=localhost
GITEA_SSH_PORT=2223
# Browser-facing CueMarshal URL used for landing-page OAuth callbacks
CUEMARSHAL_PUBLIC_URL=http://localhost:8180

# Auto-populated by init-gitea during first run
GITEA_BOT_TOKEN=
GITEA_TOKEN=${GITEA_BOT_TOKEN}

# ═══════════════════════════════════════════
# LLM Gateway (LiteLLM)
# ═══════════════════════════════════════════
# REQUIRED: Change LITELLM_MASTER_KEY before deployment
LITELLM_MASTER_KEY=CHANGE_ME_STRONG_RANDOM_STRING
GATEWAY_URL=http://gateway
GATEWAY_API_KEY=${LITELLM_MASTER_KEY}

# ═══════════════════════════════════════════
# LLM Provider API Keys
# ═══════════════════════════════════════════
# REQUIRED: Configure local Ollama or set at least one cloud provider API key
#
# Groq (Primary for tier1 and tier2) - Fast, free tier available
# Get key from: https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini (Fallback for all tiers)
# Get key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional extra Gemini keys for same-order LiteLLM load balancing
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# Azure AI (Primary for tier3)
# Get credentials from: https://ai.azure.com
AZURE_AI_API_KEY=
AZURE_AI_API_BASE=

# Anthropic Claude (Optional)
# ANTHROPIC_API_KEY=

# ═══════════════════════════════════════════
# Authentication (Optional SSO)
# ═══════════════════════════════════════════
# Enable Google OAuth for unified SSO across Gitea, Grafana, and SonarQube
# If not configured, services use standard username/password authentication
#
# Create OAuth 2.0 credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs:
#   - http://localhost:3300/user/oauth2/Google/callback  (Gitea)
#   - http://localhost:8180/grafana/login/google/callback  (Grafana)
#
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ═══════════════════════════════════════════
# Conductor (Orchestration Service)
# ═══════════════════════════════════════════
# REQUIRED: Change secrets before deployment (min 32 characters)
WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET
CONDUCTOR_SECRET=CHANGE_ME_CONDUCTOR_SECRET
CONDUCTOR_URL=http://conductor

# Webhook behavior
WEBHOOK_LOOP_THRESHOLD=10
WEBHOOK_IDEMPOTENCY_TTL=3600
BOT_USERNAMES=cuemarshal-bot,conductor-bot

# ═══════════════════════════════════════════
# MCP Servers (Tool Layer)
# ═══════════════════════════════════════════
MCP_GITEA_URL=http://mcp-gitea
MCP_CONDUCTOR_URL=http://mcp-conductor
MCP_SYSTEM_URL=http://mcp-system
MCP_VECTOR_URL=http://mcp-vector
MCP_SONAR_URL=http://mcp-sonar

# ═══════════════════════════════════════════
# Runners (Gitea Act Runner)
# ═══════════════════════════════════════════
# Auto-populated by init-gitea or via ./scripts/register-runners.sh
RUNNER_REGISTRATION_TOKEN=

# ═══════════════════════════════════════════
# Model Selection & Budget
# ═══════════════════════════════════════════
# Model tier used for different task types
CHAT_MODEL=tier2
DECOMPOSE_MODEL=tier2
PLANNING_MODEL=gpt-4o

# Complexity thresholds for tier selection
MODEL_SELECTOR_TIER1_THRESHOLD=0.30
MODEL_SELECTOR_TIER3_THRESHOLD=0.70

# Monthly budget limit (USD)
TOTAL_MONTHLY_BUDGET_USD=100.00

# ═══════════════════════════════════════════
# Retry & Escalation
# ═══════════════════════════════════════════
RETRY_MAX_TOTAL=6
RETRY_MAX_TIER1=2
RETRY_MAX_TIER2=2
RETRY_MAX_TIER3=1
RETRY_BACKOFF_BASE_MS=5000
RETRY_BACKOFF_MAX_MS=60000
RETRY_COOLDOWN_MS=10000

# ═══════════════════════════════════════════
# Self-Improvement
# ═══════════════════════════════════════════
# Percentage of monthly budget allocated to self-improvement
SELF_IMPROVE_BUDGET_PCT=10
SELF_IMPROVE_MAX_PER_CYCLE=3
SELF_IMPROVE_COOLDOWN_HOURS=4
SELF_IMPROVE_PROTECTED_PATHS=services/conductor/,services/gateway/,services/mcp-servers/,infrastructure/
SELF_IMPROVE_FAILURE_THRESHOLD=3
SELF_IMPROVE_FAILURE_WINDOW_HOURS=24
SELF_IMPROVE_TEST_MODE=false

# ═══════════════════════════════════════════
# Monitoring & Observability
# ═══════════════════════════════════════════
LOG_LEVEL=info
NODE_ENV=production

# Grafana
# If Google SSO is enabled, this password is not needed for user login
GRAFANA_ADMIN_PASSWORD=admin

# Service account token for Grafana API access (auto-populated by init-grafana if needed)
GRAFANA_SERVICE_TOKEN=

# ═══════════════════════════════════════════
# Code Quality (SonarQube)
# ═══════════════════════════════════════════
# SonarQube admin password (defaults to Gitea admin password if not set)
SONAR_ADMIN_PASSWORD=${GITEA_ADMIN_PASSWORD}
SONAR_PROJECT_KEY=cuemarshal

# Auto-populated by init-sonar during first run
SONAR_TOKEN=

# ═══════════════════════════════════════════
# Initialization
# ═══════════════════════════════════════════
# Used by init-gitea script for API authentication
API_SECRET_KEY=${CONDUCTOR_SECRET}

# ═══════════════════════════════════════════
# Optional: Local Models (Ollama)
# ═══════════════════════════════════════════
# LiteLLM defaults to this local Ollama endpoint before falling back to cloud providers
OLLAMA_BASE_URL=http://host.docker.internal:11434
ENABLE_OLLAMA=true
OLLAMA_MODELS=gemma4:26b

# ═══════════════════════════════════════════
# Validation Checklist
# ═══════════════════════════════════════════
# Before deployment:
#   1. Replace all CHANGE_ME_* values with secure random strings (min 32 chars)
#   2. Ensure local Ollama is reachable at OLLAMA_BASE_URL or set at least one cloud provider API key
#      (GROQ_API_KEY, GEMINI_API_KEY, or AZURE_AI_API_KEY). Optional: add GEMINI_API_KEY_2 and
#      GEMINI_API_KEY_3 to spread Gemini traffic across keys
#   3. Optionally configure Google OAuth for SSO
#   4. Run validation: ./scripts/validate-env.sh --prod
#   5. Start platform: docker compose up -d
#
# For interactive setup: ./install.sh
# ═══════════════════════════════════════════
