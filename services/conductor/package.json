{
  "name": "cuemarshal-conductor",
  "version": "0.0.1",
  "type": "module",
  "description": "Conductor orchestration service for CueMarshal platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "bullmq": "^5.29.3",
    "drizzle-orm": "^0.37.0",
    "express": "^4.21.2",
    "openai": "^4.77.3",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "redis": "^5.10.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.31.9",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "minimatch": "^10.2.2",
    "glob": "^13.0.0",
    "test-exclude": "^8.0.0",
    "esbuild": ">=0.25.0"
  }
}
